{
  "kind": "collectionType",
  "collectionName": "contenidos",
  "info": {
    "singularName": "contenido",
    "pluralName": "contenidos",
    "displayName": "Contenidos",
    "description": "Unidad de acceso del campus. Reemplaza los flags booleanos por usuario."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "flagLegacy": {
      "type": "string"
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "clase_anio",
        "jornada",
        "seminario",
        "curso",
        "otro"
      ],
      "default": "clase_anio"
    },
    "anio": {
      "type": "string"
    },
    "orden": {
      "type": "integer",
      "default": 0
    },
    "requiereSocio": {
      "type": "boolean",
      "default": false
    },
    "paraSocios": {
      "type": "boolean",
      "default": false
    },
    "paraAlumnos": {
      "type": "boolean",
      "default": false
    },
    "materias": {
      "type": "component",
      "repeatable": true,
      "component": "campus.materia"
    },
    "users": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user",
      "inversedBy": "contenidos"
    }
  }
}
